<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="StlExplorerClient.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:StlExplorerClient"
    Title="STL Explorer"
    Shell.BackgroundColor="#2D2D2D"
    Shell.ForegroundColor="#E0E0E0"
    Shell.TitleColor="#E0E0E0">

    <ShellContent
        Title="Catalogue"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
