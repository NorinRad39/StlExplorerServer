<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StlExplorerClient.ConfigPage"
             Title="Configuration"
             BackgroundColor="#1E1E1E">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Label Text="Dossiers racines a scanner"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="#E0E0E0" />

            <Label Text="Liste des dossiers racines configures sur le serveur pour l indexation des fichiers STL sur le NAS."
                   FontSize="13"
                   TextColor="#888" />

            <Border Stroke="#555"
                    StrokeThickness="1"
                    BackgroundColor="#2D2D2D"
                    Padding="10"
                    HeightRequest="150">
                <CollectionView x:Name="DirectoriesCollectionView" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*, 40" Padding="5,8">
                                <Label Grid.Column="0"
                                       Text="{Binding .}"
                                       TextColor="#E0E0E0"
                                       VerticalOptions="Center"
                                       FontSize="14" />
                                <Button Grid.Column="1"
                                        Text="X"
                                        TextColor="#FF6B6B"
                                        BackgroundColor="Transparent"
                                        FontSize="16"
                                        Padding="0"
                                        WidthRequest="40"
                                        HeightRequest="35"
                                        Clicked="OnSupprimerDossierClicked"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="Aucun dossier configure"
                               TextColor="#888"
                               FontAttributes="Italic"
                               HorizontalOptions="Center"
                               Margin="0,20" />
                    </CollectionView.EmptyView>
                </CollectionView>
            </Border>

            <Grid ColumnDefinitions="*, 120" ColumnSpacing="10">
                <Border Grid.Column="0"
                        Stroke="#555"
                        StrokeThickness="1"
                        BackgroundColor="#383838"
                        HeightRequest="40"
                        Padding="0">
                    <Entry x:Name="NouveauDossierEntry"
                           Placeholder="Chemin UNC (ex: \\192.168...)"
                           TextColor="#E0E0E0"
                           PlaceholderColor="#888"
                           BackgroundColor="Transparent" />
                </Border>
                <Button Grid.Column="1"
                        Text="+ Ajouter"
                        BackgroundColor="#2E7D32"
                        TextColor="White"
                        FontSize="14"
                        CornerRadius="5"
                        HeightRequest="40"
                        Clicked="OnAjouterDossierClicked" />
            </Grid>

            <HorizontalStackLayout Spacing="15" Margin="0,10,0,0">
                <Button x:Name="BtnEnregistrer"
                        Text="Enregistrer"
                        BackgroundColor="#1565C0"
                        TextColor="White"
                        FontSize="14"
                        CornerRadius="5"
                        HeightRequest="40"
                        Padding="20,0"
                        Clicked="OnEnregistrerClicked" />
                <Button x:Name="BtnRelancerScan"
                        Text="Relancer le scan"
                        BackgroundColor="#166286"
                        TextColor="White"
                        FontSize="14"
                        CornerRadius="5"
                        HeightRequest="40"
                        Padding="20,0"
                        Clicked="OnRelancerScanClicked" />
            </HorizontalStackLayout>

            <Label x:Name="StatusLabel"
                   Text=""
                   TextColor="#4CAF50"
                   FontSize="13" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
