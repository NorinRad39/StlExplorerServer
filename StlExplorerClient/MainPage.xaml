<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StlExplorerClient.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,30"
            Spacing="20">

            <!-- Formulaire hiérarchique avec ComboBox simulées (Entry + Liste) -->
            <!-- Note : MAUI n'ayant pas de ComboBox natif, on combine un Entry, un Bouton et une Liste -->
            <Grid RowSpacing="5" ColumnSpacing="15" HorizontalOptions="Start">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <!-- Ligne Famille -->
                <Label Grid.Row="0" Grid.Column="0" Text="Famille" VerticalOptions="Center" />
                <Border Grid.Row="0" Grid.Column="1" Stroke="#A2A2A2" StrokeThickness="1" HeightRequest="40" BackgroundColor="Transparent" Padding="0">
                    <Grid ColumnDefinitions="*, 35">
                        <Entry x:Name="FamilleEntry" Grid.Column="0" Placeholder="Saisir ou choisir..." TextChanged="OnFamilleTextChanged" BackgroundColor="Transparent" />
                        <Button Grid.Column="1" Text="&#x25BC;" FontSize="12" TextColor="Black" BackgroundColor="Transparent" Padding="0" Clicked="OnFamilleDropdownClicked" />
                    </Grid>
                </Border>
                <!-- Popup de suggestion Famille -->
                <Border x:Name="FamilleListContainer" Grid.Row="1" Grid.Column="1" IsVisible="False" HeightRequest="120" Stroke="#A2A2A2" StrokeThickness="1">
                    <CollectionView x:Name="FamilleCollectionView" SelectionMode="Single" SelectionChanged="OnFamilleSelectionChanged">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}" Padding="10,8" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

                <!-- Ligne Sujet -->
                <Label Grid.Row="2" Grid.Column="0" Text="Sujet" VerticalOptions="Center" />
                <Border Grid.Row="2" Grid.Column="1" Stroke="#A2A2A2" StrokeThickness="1" HeightRequest="40" BackgroundColor="Transparent" Padding="0">
                    <Grid ColumnDefinitions="*, 35">
                        <Entry x:Name="SujetEntry" Grid.Column="0" Placeholder="Saisir ou choisir..." TextChanged="OnSujetTextChanged" BackgroundColor="Transparent" />
                        <Button Grid.Column="1" Text="&#x25BC;" FontSize="12" TextColor="Black" BackgroundColor="Transparent" Padding="0" Clicked="OnSujetDropdownClicked" />
                    </Grid>
                </Border>
                <!-- Popup de suggestion Sujet -->
                <Border x:Name="SujetListContainer" Grid.Row="3" Grid.Column="1" IsVisible="False" HeightRequest="120" Stroke="#A2A2A2" StrokeThickness="1">
                    <CollectionView x:Name="SujetCollectionView" SelectionMode="Single" SelectionChanged="OnSujetSelectionChanged">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}" Padding="10,8" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

                <!-- Ligne Modèle -->
                <Label Grid.Row="4" Grid.Column="0" Text="Modèle" VerticalOptions="Center" />
                <Border Grid.Row="4" Grid.Column="1" Stroke="#A2A2A2" StrokeThickness="1" HeightRequest="40" BackgroundColor="Transparent" Padding="0">
                    <Grid ColumnDefinitions="*, 35">
                        <Entry x:Name="ModeleEntry" Grid.Column="0" Placeholder="Saisir ou choisir..." TextChanged="OnModeleTextChanged" BackgroundColor="Transparent" />
                        <Button Grid.Column="1" Text="&#x25BC;" FontSize="12" TextColor="Black" BackgroundColor="Transparent" Padding="0" Clicked="OnModeleDropdownClicked" />
                    </Grid>
                </Border>
                <!-- Popup de suggestion Modèle -->
                <Border x:Name="ModeleListContainer" Grid.Row="5" Grid.Column="1" IsVisible="False" HeightRequest="120" Stroke="#A2A2A2" StrokeThickness="1">
                    <CollectionView x:Name="ModeleCollectionView" SelectionMode="Single" SelectionChanged="OnModeleSelectionChanged">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}" Padding="10,8" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </Grid>

            <!-- Zone Image de prévisualisation -->
            <Border Stroke="#333" 
                    StrokeThickness="1" 
                    HeightRequest="400" 
                    HorizontalOptions="Fill" 
                    Margin="0,15,0,0">
                <Grid>
                    <!-- Texte en haut à gauche comme sur le croquis -->
                    <Label Text="Image" 
                           Margin="10" 
                           HorizontalOptions="Start" 
                           VerticalOptions="Start" />

                    <Image x:Name="ModeleImage" Aspect="AspectFit" Margin="5" />
                </Grid>
            </Border>

            <!-- Boutons de navigation des images -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="40" Margin="0,10,0,0">
                <Button x:Name="BtnImagePrecedente" 
                        Text="&#x25C0;" 
                        FontSize="24" 
                        WidthRequest="100" 
                        HeightRequest="45" 
                        BackgroundColor="#166286"
                        CornerRadius="5"
                        ToolTipProperties.Text="Image précédente" />

                <Button x:Name="BtnImageSuivante" 
                        Text="&#x25B6;" 
                        FontSize="24" 
                        WidthRequest="100" 
                        HeightRequest="45" 
                        BackgroundColor="#166286"
                        CornerRadius="5"
                        ToolTipProperties.Text="Image suivante" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
