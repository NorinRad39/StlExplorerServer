<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StlExplorerClient.MainPage"
             Title="Catalogue"
             BackgroundColor="#1E1E1E">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="⚙ Config" Clicked="OnConfigClicked" />
    </ContentPage.ToolbarItems>

    <Grid>
        <!-- Contenu principal -->
        <ScrollView>
            <VerticalStackLayout
                Padding="30"
                Spacing="20">

                <!-- Formulaire hiérarchique avec ComboBox simulées -->
                <Grid RowSpacing="5" ColumnSpacing="15" HorizontalOptions="Start">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="350" />
                    </Grid.ColumnDefinitions>

                    <!-- Ligne Famille -->
                    <Label Grid.Row="0" Grid.Column="0" Text="Famille" VerticalOptions="Center" TextColor="#E0E0E0" />
                    <Border Grid.Row="0" Grid.Column="1" Stroke="#555" StrokeThickness="1" HeightRequest="40" BackgroundColor="#383838" Padding="0">
                        <Grid ColumnDefinitions="*, 30, 35">
                            <Entry x:Name="FamilleEntry" Grid.Column="0" Placeholder="Saisir ou choisir..." TextColor="#E0E0E0" PlaceholderColor="#888" TextChanged="OnFamilleTextChanged" BackgroundColor="Transparent" />
                            <Button Grid.Column="1" Text="✕" FontSize="11" TextColor="#888" BackgroundColor="Transparent" Padding="0" Clicked="OnFamilleClearClicked" />
                            <Button Grid.Column="2" Text="&#x25BC;" FontSize="12" TextColor="#E0E0E0" BackgroundColor="Transparent" Padding="0" Clicked="OnFamilleDropdownClicked" />
                        </Grid>
                    </Border>
                    <Border x:Name="FamilleListContainer" Grid.Row="1" Grid.Column="1" IsVisible="False" HeightRequest="120" Stroke="#555" StrokeThickness="1" BackgroundColor="#2D2D2D">
                        <CollectionView x:Name="FamilleCollectionView" SelectionMode="Single" SelectionChanged="OnFamilleSelectionChanged">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding .}" Padding="10,8" TextColor="#E0E0E0" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>

                    <!-- Ligne Sujet -->
                    <Label Grid.Row="2" Grid.Column="0" Text="Sujet" VerticalOptions="Center" TextColor="#E0E0E0" />
                    <Border Grid.Row="2" Grid.Column="1" Stroke="#555" StrokeThickness="1" HeightRequest="40" BackgroundColor="#383838" Padding="0">
                        <Grid ColumnDefinitions="*, 30, 35">
                            <Entry x:Name="SujetEntry" Grid.Column="0" Placeholder="Saisir ou choisir..." TextColor="#E0E0E0" PlaceholderColor="#888" TextChanged="OnSujetTextChanged" BackgroundColor="Transparent" />
                            <Button Grid.Column="1" Text="✕" FontSize="11" TextColor="#888" BackgroundColor="Transparent" Padding="0" Clicked="OnSujetClearClicked" />
                            <Button Grid.Column="2" Text="&#x25BC;" FontSize="12" TextColor="#E0E0E0" BackgroundColor="Transparent" Padding="0" Clicked="OnSujetDropdownClicked" />
                        </Grid>
                    </Border>
                    <Border x:Name="SujetListContainer" Grid.Row="3" Grid.Column="1" IsVisible="False" HeightRequest="120" Stroke="#555" StrokeThickness="1" BackgroundColor="#2D2D2D">
                        <CollectionView x:Name="SujetCollectionView" SelectionMode="Single" SelectionChanged="OnSujetSelectionChanged">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding .}" Padding="10,8" TextColor="#E0E0E0" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>

                    <!-- Ligne Modèle -->
                    <Label Grid.Row="4" Grid.Column="0" Text="Modèle" VerticalOptions="Center" TextColor="#E0E0E0" />
                    <Border Grid.Row="4" Grid.Column="1" Stroke="#555" StrokeThickness="1" HeightRequest="40" BackgroundColor="#383838" Padding="0">
                        <Grid ColumnDefinitions="*, 30, 35">
                            <Entry x:Name="ModeleEntry" Grid.Column="0" Placeholder="Saisir ou choisir..." TextColor="#E0E0E0" PlaceholderColor="#888" TextChanged="OnModeleTextChanged" BackgroundColor="Transparent" />
                            <Button Grid.Column="1" Text="✕" FontSize="11" TextColor="#888" BackgroundColor="Transparent" Padding="0" Clicked="OnModeleClearClicked" />
                            <Button Grid.Column="2" Text="&#x25BC;" FontSize="12" TextColor="#E0E0E0" BackgroundColor="Transparent" Padding="0" Clicked="OnModeleDropdownClicked" />
                        </Grid>
                    </Border>
                    <Border x:Name="ModeleListContainer" Grid.Row="5" Grid.Column="1" IsVisible="False" HeightRequest="120" Stroke="#555" StrokeThickness="1" BackgroundColor="#2D2D2D">
                        <CollectionView x:Name="ModeleCollectionView" SelectionMode="Single" SelectionChanged="OnModeleSelectionChanged">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding .}" Padding="10,8" TextColor="#E0E0E0" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>
                </Grid>

                <!-- Zone d'actions (Windows uniquement) -->
                <HorizontalStackLayout x:Name="WindowsActionsPanel" IsVisible="False" Spacing="10" HorizontalOptions="Start">
                    <Button x:Name="BtnCreerDossier" 
                            Text="📁 Créer le dossier" 
                            BackgroundColor="#2E7D32"
                            TextColor="White"
                            FontSize="14"
                            CornerRadius="5"
                            HeightRequest="40"
                            Padding="15,0"
                            IsVisible="False"
                            Clicked="OnCreerDossierClicked" />
                    <Button x:Name="BtnAjouterFichiers" 
                            Text="📎 Ajouter des fichiers" 
                            BackgroundColor="#1565C0"
                            TextColor="White"
                            FontSize="14"
                            CornerRadius="5"
                            HeightRequest="40"
                            Padding="15,0"
                            IsVisible="False"
                            Clicked="OnAjouterFichiersClicked" />
                    <Button x:Name="BtnRenommerModele" 
                            Text="✏ Renommer" 
                            BackgroundColor="#F57F17"
                            TextColor="White"
                            FontSize="14"
                            CornerRadius="5"
                            HeightRequest="40"
                            Padding="15,0"
                            IsVisible="False"
                            Clicked="OnRenommerModeleClicked" />
                    <Button x:Name="BtnOuvrirExplorateur" 
                            Text="📂 Ouvrir le dossier" 
                            BackgroundColor="#6A1B9A"
                            TextColor="White"
                            FontSize="14"
                            CornerRadius="5"
                            HeightRequest="40"
                            Padding="15,0"
                            IsVisible="False"
                            Clicked="OnOuvrirExplorateurClicked" />
        <Button x:Name="BtnActualiserBase"
                Text="🔄 Actualiser la base"
                BackgroundColor="#455A64"
                TextColor="White"
                FontSize="14"
                CornerRadius="5"
                HeightRequest="40"
                Padding="15,0"
                HorizontalOptions="Start"
                Clicked="OnActualiserBaseClicked" />
                </HorizontalStackLayout>

                <!-- Contenu du dossier (fichiers et sous-dossiers à la racine) -->
                <Border x:Name="ContenuDossierPanel" IsVisible="False" Stroke="#555" StrokeThickness="1" BackgroundColor="#2D2D2D" Padding="10">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="📂 Contenu du dossier" FontSize="14" FontAttributes="Bold" TextColor="#E0E0E0" />
                        <CollectionView x:Name="ContenuDossierCollectionView" HeightRequest="100">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding .}" Padding="5,3" TextColor="#CCC" FontSize="13" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Fichiers 3D détectés (cliquables pour aperçu) -->
                <Border x:Name="Fichiers3DPanel" IsVisible="False" Stroke="#555" StrokeThickness="1" BackgroundColor="#2D2D2D" Padding="10">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="🧊 Fichiers 3D" FontSize="14" FontAttributes="Bold" TextColor="#E0E0E0" />
                        <CollectionView x:Name="Fichiers3DCollectionView" HeightRequest="120" SelectionMode="Single" SelectionChanged="OnFichier3DSelectionChanged">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding Affichage}" Padding="5,3" TextColor="#4FC3F7" FontSize="13" TextDecorations="Underline" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Zone de prévisualisation (image ou viewer 3D) -->
                <Border Stroke="#555" 
                        StrokeThickness="1" 
                        HeightRequest="450" 
                        HorizontalOptions="Fill" 
                        Margin="0,15,0,0"
                        BackgroundColor="#2D2D2D">
                    <Grid>
                        <Image x:Name="ModeleImage" Aspect="AspectFit" Margin="5">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnImageTapped" />
                            </Image.GestureRecognizers>
                        </Image>
                        <WebView x:Name="Viewer3DWebView" IsVisible="False" />
                    </Grid>
                </Border>

                <!-- Bouton retour aux images (visible quand le viewer 3D est actif) -->
                <Button x:Name="BtnRetourImages" 
                        Text="🖼 Retour aux images" 
                        BackgroundColor="#555" 
                        TextColor="White" 
                        FontSize="14" 
                        CornerRadius="5" 
                        HeightRequest="40" 
                        Padding="15,0" 
                        HorizontalOptions="Center"
                        IsVisible="False" 
                        Clicked="OnRetourImagesClicked" />

                <!-- Boutons de navigation des images -->
                <HorizontalStackLayout x:Name="ImageNavPanel" HorizontalOptions="Center" Spacing="20" Margin="0,10,0,0">
                    <Button x:Name="BtnImagePrecedente" 
                            Text="&#x25C0;" 
                            FontSize="24" 
                            WidthRequest="100" 
                            HeightRequest="45" 
                            BackgroundColor="#166286"
                            TextColor="White"
                            CornerRadius="5"
                            ToolTipProperties.Text="Image précédente"
                            Clicked="OnImagePrecedenteClicked" />

                    <Label x:Name="ImageCounterLabel" 
                           Text="" 
                           TextColor="#E0E0E0" 
                           FontSize="16" 
                           VerticalOptions="Center" 
                           HorizontalOptions="Center"
                           WidthRequest="80"
                           HorizontalTextAlignment="Center" />

                    <Button x:Name="BtnImageSuivante" 
                            Text="&#x25B6;" 
                            FontSize="24" 
                            WidthRequest="100" 
                            HeightRequest="45" 
                            BackgroundColor="#166286"
                            TextColor="White"
                            CornerRadius="5"
                            ToolTipProperties.Text="Image suivante"
                            Clicked="OnImageSuivanteClicked" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Overlay plein écran pour agrandir l'image (clic pour fermer) -->
        <Grid x:Name="ImageOverlay" IsVisible="False" BackgroundColor="#DD000000" ZIndex="100">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnImageOverlayTapped" />
            </Grid.GestureRecognizers>
            <Image x:Name="EnlargedImage" Aspect="AspectFit" Margin="30" />
            <Label Text="Cliquer pour fermer" 
                   TextColor="#AAA" 
                   FontSize="13" 
                   HorizontalOptions="Center" 
                   VerticalOptions="End" 
                   Margin="0,0,0,15" />
        </Grid>
    </Grid>

</ContentPage>
